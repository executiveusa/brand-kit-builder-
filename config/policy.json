    "api_key",
    "access_token",
    "refresh_token",
    "password",
    "secret",
    "private_key",
    "authorization",
    "cookie"
  ],
  "network_listener_enabled": false,
  "external_model_calls_enabled": false,
  "telemetry_enabled": false
}
