{
  "schema_version": "1.0",
  "owner": "Bambu",
  "release_floor": 8.5,
  "critical_axis_floor": 8.0,
  "maximum_job_cost_cents": 1000,
  "maximum_daily_cost_cents": 5000,
  "production_deploy_requires_explicit_approval": true,
  "export_requires_explicit_approval": true,
  "required_guardians": ["brand", "design", "voice", "rights"],
