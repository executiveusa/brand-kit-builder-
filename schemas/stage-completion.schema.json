{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pauli.effect/schemas/stage-completion.schema.json",
  "title": "Brand Kit Builder Stage Completion",
  "type": "object",
  "additionalProperties": true,
  "required": ["project_id", "stage", "idempotency_key", "artifacts"],
  "properties": {
    "project_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "stage": { "enum": ["intake", "sources", "readiness", "strategy", "voice", "visual", "brandbook", "guardian", "export"] },
    "idempotency_key": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "media_type": { "type": "string" }
        }
      }
    },
    "sources": { "type": "array", "items": { "$ref": "source-ledger.schema.json#/$defs/source" } },
    "readiness_scores": { "type": "object", "minProperties": 20, "maxProperties": 20 },
    "guardians": { "type": "object" },
    "guardian_summary": {
      "type": "object",
      "properties": {
        "p0": { "type": "integer", "minimum": 0 },
        "unresolved_p1": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
