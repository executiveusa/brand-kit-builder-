{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pauli.effect/schemas/brand-kit-project.schema.json",
  "title": "Brand Kit Builder Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_id", "name", "classification", "sources"],
  "properties": {
    "project_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "name": { "type": "string", "minLength": 2, "maxLength": 160 },
    "classification": {
      "enum": ["greenfield", "brownfield", "hybrid", "recovery", "asset-extension", "brand-refresh", "full-rebrand"]
    },
    "owner": { "type": "string", "default": "Bambu" },
    "primary_audience": { "type": "string" },
    "business_goal": { "type": "string" },
    "primary_action": { "type": "string" },
    "languages": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "protected_assets": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "source-ledger.schema.json#/$defs/source" }
    },
    "readiness": {
      "type": "object",
      "properties": {
        "scores": { "type": "object", "minProperties": 20, "maxProperties": 20, "additionalProperties": { "type": "number", "minimum": 0, "maximum": 10 } }
      },
      "required": ["scores"]
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "approved_by", "status", "approved_at"],
        "properties": {
          "action": { "type": "string" },
          "approved_by": { "type": "string" },
          "status": { "const": "approved" },
          "approved_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
